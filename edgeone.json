{
  "buildCommand": "echo 'Build completed'",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/cloud-functions/api/[[default]].py"
    }
  ],
  "cloudFunctions": {
    "python": {
      "maxDuration": 30
    }
  },
  "overseasRegions": ["ap-singapore"]
}

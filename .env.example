# EdgeOne Pages API Token
# 用于 CLI 自动部署
EO_API_TOKEN=your-api-token-here

# 数据库配置
DB_HOST=your-db-host.tencentcloud.com
DB_PORT=3306
DB_NAME=sfm_cloud
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT 密钥 (请生成一个随机字符串)
JWT_SECRET=your-random-jwt-secret-key
JWT_EXPIRE_DAYS=7

# 支持的语言列表 (ISO 639-1 代码)
SUPPORTED_LANGUAGES=zh,en,ja,ko,ru,fr,de
DEFAULT_LANGUAGE=en
